<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pp_v2_background"
    android:orientation="vertical">

    <include
        android:id="@+id/combinedSheetHeader"
        layout="@layout/include_pp_sheet_header_v2" />

    
    <include
        android:id="@+id/combinedSearchField"
        layout="@layout/include_pp_search_field_v2"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginStart="@dimen/pp_v2_spacing_s16"
        android:layout_marginEnd="@dimen/pp_v2_spacing_s16"
        android:layout_marginTop="@dimen/pp_v2_spacing_s16"
        android:layout_marginBottom="@dimen/pp_v2_spacing_s16" />

    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/pp_v2_content_card_bg"
        android:orientation="vertical"
        android:paddingTop="@dimen/pp_v2_spacing_s16">

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/pp_v2_spacing_s16"
            android:paddingEnd="@dimen/pp_v2_spacing_s16">

            <LinearLayout
                android:id="@+id/combinedVaultSelectorContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/pp_v2_list_item_bg"
                android:orientation="vertical">

                
                <LinearLayout
                    android:id="@+id/combinedVaultSelector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/pp_v2_spacing_s12"
                    android:paddingEnd="@dimen/pp_v2_spacing_s12"
                    android:paddingTop="@dimen/pp_v2_spacing_s12"
                    android:paddingBottom="@dimen/pp_v2_spacing_s12">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="@dimen/pp_v2_spacing_s8"
                        android:contentDescription="@null"
                        android:src="@drawable/pp_v2_ic_lock"
                        app:tint="@color/pp_v2_text_primary" />

                    <TextView
                        android:id="@+id/combinedVaultSelectorTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.PearPass.V2.LabelEmphasized"
                        android:textColor="@color/pp_v2_text_primary"
                        tools:text="Personal Vault" />

                    <ImageView
                        android:id="@+id/combinedVaultSelectorChevron"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="@dimen/pp_v2_spacing_s8"
                        android:contentDescription="@null"
                        android:src="@drawable/pp_v2_ic_chevron_down"
                        app:tint="@color/pp_v2_text_primary" />
                </LinearLayout>

                
                <View
                    android:id="@+id/combinedVaultDropdownDivider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/pp_v2_border_primary"
                    android:visibility="gone" />

                
                <LinearLayout
                    android:id="@+id/combinedVaultDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/pp_v2_spacing_s12"
                    android:paddingEnd="@dimen/pp_v2_spacing_s12"
                    android:paddingTop="@dimen/pp_v2_spacing_s12"
                    android:paddingBottom="@dimen/pp_v2_spacing_s12"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="@dimen/pp_v2_spacing_s12"
            android:layout_marginEnd="@dimen/pp_v2_spacing_s12"
            android:layout_marginTop="@dimen/pp_v2_spacing_s12"
            android:background="@color/pp_v2_border_primary" />

        
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="@dimen/pp_v2_spacing_s16"
            android:paddingEnd="@dimen/pp_v2_spacing_s16">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/combinedCredentialsList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="@dimen/pp_v2_spacing_s8"
                android:clipToPadding="false" />

            
            <TextView
                android:id="@+id/combinedEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:layout_marginTop="@dimen/pp_v2_spacing_s16"
                android:textAppearance="@style/TextAppearance.PearPass.V2.Label"
                android:textColor="@color/pp_v2_text_secondary"
                android:visibility="gone" />

            
            <ProgressBar
                android:id="@+id/combinedLoading"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/pp_v2_primary"
                android:visibility="gone" />

            
            <LinearLayout
                android:id="@+id/combinedVaultPasswordGroup"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingTop="@dimen/pp_v2_spacing_s24"
                android:visibility="gone">

                <TextView
                    android:id="@+id/combinedVaultPasswordTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Unlock Vault"
                    android:textAppearance="@style/TextAppearance.PearPass.V2.BodyEmphasized"
                    android:textColor="@color/pp_v2_text_primary" />

                <TextView
                    android:id="@+id/combinedVaultPasswordSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/pp_v2_spacing_s8"
                    android:gravity="center"
                    android:text="Enter vault password to continue"
                    android:textAppearance="@style/TextAppearance.PearPass.V2.Label"
                    android:textColor="@color/pp_v2_text_secondary"
                    tools:text="Enter vault password to continue" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/pp_v2_spacing_s24" />

                <include
                    android:id="@+id/combinedVaultPasswordField"
                    layout="@layout/include_pp_password_field_v2" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/combinedVaultPasswordContinue"
                    style="@style/Button.PearPass.V2.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/pp_v2_spacing_s16"
                    android:layout_marginBottom="@dimen/pp_v2_spacing_s16"
                    android:text="Continue" />
            </LinearLayout>
        </FrameLayout>

        
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="@dimen/pp_v2_spacing_s12"
            android:layout_marginEnd="@dimen/pp_v2_spacing_s12"
            android:background="@color/pp_v2_border_primary" />

        
        <LinearLayout
            android:id="@+id/combinedAddNewButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/pp_v2_spacing_s16"
            android:layout_marginEnd="@dimen/pp_v2_spacing_s16"
            android:layout_marginTop="@dimen/pp_v2_spacing_s16"
            android:layout_marginBottom="@dimen/pp_v2_spacing_s32"
            android:background="@drawable/pp_v2_btn_primary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="@dimen/pp_v2_spacing_s12"
            android:paddingEnd="@dimen/pp_v2_spacing_s12"
            android:paddingTop="@dimen/pp_v2_spacing_s12"
            android:paddingBottom="@dimen/pp_v2_spacing_s12">

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="@dimen/pp_v2_spacing_s8"
                android:contentDescription="@null"
                android:src="@drawable/pp_v2_ic_plus" />

            <TextView
                android:fontFamily="@font/pp_v2_inter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add New Login"
                android:textColor="@color/pp_v2_on_primary"
                android:textFontWeight="500"
                android:textSize="@dimen/pp_v2_font_s14"
                android:textStyle="normal" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
