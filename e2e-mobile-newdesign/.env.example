################################
# PLATFORM & TARGET
################################
PLATFORM=Android
RUN_TARGET=bs

################################
# BROWSERSTACK CONFIGURATION
################################
BROWSERSTACK_USERNAME=your_bs_username
BROWSERSTACK_ACCESS_KEY=your_bs_access_key
BSTACK_LOCAL=false

# BrowserStack Device Selection
BS_ANDROID_DEVICE=Samsung Galaxy S24
BS_ANDROID_VERSION=14.0
BS_IOS_DEVICE=iPhone 15 Pro
BS_IOS_VERSION=17

################################
# LOCAL DEVICE CONFIGURATION
################################
ANDROID_DEVICE_NAME=Android Emulator
ANDROID_PLATFORM_VERSION=16
ANDROID_AVD_NAME=Pixel_9_API_36

IOS_DEVICE_NAME=iPhone 15 Pro
IOS_PLATFORM_VERSION=17

################################
# APP PATHS & METADATA
################################
ANDROID_APP=PearPass.apk
IOS_APP=PearPass.ipa

# Android App Package (Optional)
# APP_PACKAGE=com.pearpass.app
# APP_ACTIVITY=com.pearpass.app.MainActivity

BUILD_PREFIX=PearPass E2E
APP_VERSION=2.1.0

################################
# QASE TEST MANAGEMENT
################################
ENABLE_QASE=true
QASE_API_TOKEN=your_qase_api_token_here
QASE_PROJECT_CODE=PAS

# Optional: Test Plan for sync scope and/or run creation (see Qase → Plans).
QASE_TESTOPS_PLAN_ID=2

# Repository suite (folder) ID from the URL: .../project/PAS?suite=25
# When set, sync loads case IDs from this suite instead of the plan, and new cases are created under this suite.
QASE_SUITE_ID=25

QASE_RUN_ID=0

QASE_SYNC=true

################################
# SLACK NOTIFICATIONS
################################
ENABLE_SLACK=false
# Paste the Incoming Webhook URL from Slack (Settings → Integrations). Never commit a real URL.
SLACK_WEBHOOK_URL=

################################
# NPM SCRIPTS (see package.json)
################################
# Full core E2E on BrowserStack (Onboarding, SignUp, Settings, Home): npm run e2e:android:bs
# Same five suites on local emulator + test data push: npm run test:all
# Auth-only on BS (Onboarding + SignUp): npm run e2e:android:bs:auth
